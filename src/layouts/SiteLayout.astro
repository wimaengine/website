---
import '../styles/wima.css';
import brandIconDark from '../assets/images/logo/wima-logo-dark.png';
import brandIconLight from '../assets/images/logo/wima-logo-light.png';
import brandSocialImage from '../assets/images/logo/wima-logo-long-light.png';
import { withBase } from '../lib/url';

interface SocialImage {
	src: string;
	width: number;
	height: number;
}

interface Props {
	title: string;
	description: string;
	noindex?: boolean;
	refreshTo?: string;
	canonicalHref?: string;
	socialImage?: SocialImage;
	socialImageAlt?: string;
}

const {
	title,
	description,
	noindex = false,
	refreshTo,
	canonicalHref,
	socialImage = brandSocialImage,
	socialImageAlt,
} = Astro.props as Props;
const siteTitle = 'Wima Engine';
const pageTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;
const pathname = Astro.url.pathname;
const normalizedPath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');
const normalizeHref = (href: string) => (href === '/' ? '/' : href.replace(/\/$/, ''));
const pageUrl = canonicalHref ?? (Astro.site ? new URL(pathname, Astro.site).toString() : undefined);
const socialImageUrl = socialImage ? (Astro.site ? new URL(socialImage.src, Astro.site).toString() : socialImage.src) : undefined;
const socialImageText = socialImageAlt ?? `${siteTitle} logo`;
const navItems = [
	{ href: 'https://github.com/wimaengine/wima/discussions', label: 'Community' },
	{ href: '/news/', label: 'News' },
	{ href: '/releases/', label: 'Releases' },
	{ href: 'https://docs.wimaengine.org/', label: 'Docs' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="color-scheme" content="light dark" />
		<meta name="theme-color" content="#eef3f1" />
		<link rel="icon" type="image/png" href={brandIconLight.src} />
		<link rel="icon" type="image/png" href={brandIconDark.src} media="(prefers-color-scheme: dark)" />
		<link rel="apple-touch-icon" href={brandIconLight.src} />
		{noindex ? <meta name="robots" content="noindex, nofollow" /> : null}
		{refreshTo ? <meta http-equiv="refresh" content={`0; url=${refreshTo}`} /> : null}
		{pageUrl ? <link rel="canonical" href={pageUrl} /> : null}
		{pageUrl ? <meta property="og:url" content={pageUrl} /> : null}
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content={siteTitle} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="en_US" />
		{socialImageUrl ? <meta property="og:image" content={socialImageUrl} /> : null}
		{socialImageUrl ? <meta property="og:image:width" content={String(socialImage.width)} /> : null}
		{socialImageUrl ? <meta property="og:image:height" content={String(socialImage.height)} /> : null}
		{socialImageUrl ? <meta property="og:image:alt" content={socialImageText} /> : null}
		<meta name="twitter:card" content={socialImageUrl ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{socialImageUrl ? <meta name="twitter:image" content={socialImageUrl} /> : null}
		{socialImageUrl ? <meta name="twitter:image:alt" content={socialImageText} /> : null}
	</head>
	<body>
		<a class="wima-skip-link" href="#content">Skip to content</a>
		<header class="wima-header">
			<a class="wima-brand" href={withBase('/')} aria-label="Wima Engine home">
				<picture class="wima-brand__logo">
					<source srcset={brandIconDark.src} media="(prefers-color-scheme: dark)" />
					<img
						src={brandIconLight.src}
						width={brandIconLight.width}
						height={brandIconLight.height}
						alt=""
						aria-hidden="true"
						loading="eager"
						decoding="async"
					/>
				</picture>
				<span class="wima-brand__text">
					<span class="wima-brand__name">Wima Engine</span>
				</span>
			</a>

			<nav class="wima-nav" aria-label="Primary">
				{navItems.map((item) => {
					const href = withBase(item.href);
					const ariaCurrent = href.startsWith('http')
						? undefined
						: normalizeHref(href) === normalizedPath
							? 'page'
							: undefined;

					return (
						<a class="wima-nav__link" href={href} aria-current={ariaCurrent}>
							{item.label}
						</a>
					);
				})}
			</nav>
		</header>

		<main id="content" class="wima-main">
			<slot />
		</main>

		<footer class="wima-footer">
			<a class="wima-footer__link" href="https://github.com/wimaengine/wima">GitHub</a>
		</footer>
	</body>
</html>
